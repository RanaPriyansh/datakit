# datakit Environment Configuration
# Copy this file to .env and adjust values as needed

# Logging configuration
DATATKIT_LOG_LEVEL=INFO
# DATATKIT_LOG_FILE=/var/log/datakit.log  # Optional
# DATATKIT_LOG_JSON=false  # Set to 'true' for JSON logs

# Optional: Default paths for frequently used files
# DATATKIT_DEFAULT_INPUT_DIR=./data
# DATATKIT_DEFAULT_OUTPUT_DIR=./output
